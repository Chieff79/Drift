<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.drift.vpn</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Drift</name>
  <summary>Fast &amp; Secure Connection</summary>

  <developer_name>Drift</developer_name>
  <update_contact>support@drift-vpn.app</update_contact>

  <description>
    <p>
      Drift is a fast and secure connection tool with built-in servers in NL, RU, and US.
      Supports multiple protocols including VLESS, VMess, Shadowsocks, Trojan, Hysteria2,
      WireGuard, and more via the sing-box core.
    </p>
    <p>
      Simple one-tap connection with subscription support and automatic updates.
    </p>
  </description>

  <launchable type="desktop-id">com.drift.vpn.desktop</launchable>

  <icon type="stock">drift-vpn</icon>

  <categories>
    <category>Network</category>
  </categories>

  <keywords>
    <keyword>Drift</keyword>
    <keyword>Privacy</keyword>
    <keyword>Proxy</keyword>
    <keyword>V2Ray</keyword>
    <keyword>VLESS</keyword>
    <keyword>Xray</keyword>
    <keyword>WireGuard</keyword>
  </keywords>

  <mime-types>
    <mime-type>x-scheme-handler/drift</mime-type>
    <mime-type>x-scheme-handler/v2ray</mime-type>
    <mime-type>x-scheme-handler/v2rayn</mime-type>
    <mime-type>x-scheme-handler/v2rayng</mime-type>
    <mime-type>x-scheme-handler/clash</mime-type>
    <mime-type>x-scheme-handler/clashmeta</mime-type>
    <mime-type>x-scheme-handler/sing-box</mime-type>
  </mime-types>

  <url type="homepage">https://drift-vpn.app</url>
  <url type="bugtracker">https://github.com/Chieff79/Drift/issues</url>
  <url type="help">https://t.me/driftvpn</url>

  <provides>
    <binary>drift</binary>
  </provides>

  <releases>
    <release version="4.1.2" date="2025-03-19">
      <description>
        <p>Drift — Fast &amp; Secure Connection with built-in NL, RU, US servers.</p>
      </description>
    </release>
  </releases>

  <translation type="gettext">drift</translation>

  <custom>
    <value key="PackageName">drift-vpn</value>
    <value key="Priority">optional</value>
    <value key="Section">x11</value>
    <value key="Essential">false</value>
  </custom>
</component>
